# Asofe — local environment template
# Copy this file to `.env.local` and fill in real values, OR run
# `vercel env pull .env.local` once the project is linked.

# ─── Supabase (auto-provisioned via Vercel Marketplace) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
POSTGRES_URL_NON_POOLING=

# ─── Stripe (required for live checkout) ─────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Resend (transactional email) ────────────────────────────────────────
# If unset, emails silently no-op (orders still place; webhook still runs).
RESEND_API_KEY=

# ─── Optional: error tracking ────────────────────────────────────────────
# Add when you spin up a Sentry project. Without these the app runs fine,
# but unhandled errors are only visible via `vercel logs`.
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

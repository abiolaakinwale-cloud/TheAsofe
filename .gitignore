# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# OS / editor
Thumbs.db
.vscode/
.idea/

# Large source assets — keep zip archives out of git history
# (the PNGs themselves are kept in asofe images/ as the canonical source set
# and copied with kebab-case names into public/asofe/)
*.zip

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local
